# Band / Thenvoi platform
THENVOI_REST_URL=https://app.band.ai/
THENVOI_WS_URL=wss://app.band.ai/api/v1/socket/websocket

# AI/ML API (powers all 3 agent brains AND the Analyst's bounded narrative call)
AIML_API_KEY=your_aiml_api_key_here
# Confirm exact namespaced model id in the AI/ML Playground (e.g. openai/gpt-4o-mini)
AIML_MODEL=openai/gpt-4o-mini

# Database
DATABASE_URL=postgresql+asyncpg://marketsense:marketsense@localhost:5432/marketsense

# Notifications & HiTL
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
HITL_API_URL=http://localhost:8000

# Business rules
MARGIN_FLOOR_PCT=6.0
MAX_PRICE_CHANGE_PCT=15.0
PRICE_DROP_THRESHOLD_PCT=5.0
